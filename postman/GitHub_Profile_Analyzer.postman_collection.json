{
  "info": {
    "name": "GitHub Profile Analyzer API",
    "description": "Postman Collection for GitHub Profile Analyzer API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Analyze Profile",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"octocat\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/github/analyze",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "analyze"]
        }
      }
    },
    {
      "name": "Get Profiles (Paginated)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/profiles?page=1&limit=10&sort=score&order=desc",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "profiles"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" },
            { "key": "sort", "value": "score" },
            { "key": "order", "value": "desc" }
          ]
        }
      }
    },
    {
      "name": "Get Single Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/profiles/octocat",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "profiles", "octocat"]
        }
      }
    },
    {
      "name": "Reanalyze Profile",
      "request": {
        "method": "PUT",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/reanalyze/octocat",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "reanalyze", "octocat"]
        }
      }
    },
    {
      "name": "Delete Profile",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/profiles/octocat",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "profiles", "octocat"]
        }
      }
    },
    {
      "name": "Get Top Leaderboard",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/top",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "top"]
        }
      }
    },
    {
      "name": "Get Stats",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/github/stats",
          "host": ["{{baseUrl}}"],
          "path": ["api", "github", "stats"]
        }
      }
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ]
}
